import matplotlib.pyplot as plt

# simple, realistic sample (replace later with your real data if you want)
regions = ["North", "South", "East", "West"]
revenue = [52000, 39000, 24500, 18900]

plt.figure(figsize=(6,4))
plt.bar(regions, revenue)
plt.title("Revenue by Region")
plt.xlabel("Region")
plt.ylabel("Revenue ($)")
plt.tight_layout()

plt.savefig("thumbnail.png", dpi=200)
plt.close()

print("Saved thumbnail.png")
